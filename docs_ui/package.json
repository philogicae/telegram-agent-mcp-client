{
  "name": "@philogicae/docs_ui",
  "description": "Docs UI for Telegram Agent",
  "version": "1.0.0",
  "repository": "https://github.com/philogicae/telegram-agent-mcp-client/docs_ui",
  "private": true,
  "author": "@philogicae",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 4040 --turbo",
    "lint": "biome check --write app --unsafe",
    "build": "next build --turbo",
    "start": "next start -H 0.0.0.0 -p 4040",
    "upgrade": "pnpm update && pnpm prune",
    "clean": "rimraf .next && rimraf out && rimraf node_modules && pnpm install",
    "repomix": "pnpx repomix --style markdown --remove-empty-lines"
  },
  "dependencies": {
    "@heroui/react": "^2.8.9",
    "@tanstack/react-query": "^5.90.21",
    "dompurify": "^3.3.2",
    "framer-motion": "^12.35.0",
    "html2pdf.js": "^0.14.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "postcss": "^8.5.8",
    "serve": "^14.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
